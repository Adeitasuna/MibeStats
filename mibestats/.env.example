# =====================================================
# MibeStats — Environment Variables
# Copy to .env and fill in your values
# =====================================================

# Supabase PostgreSQL (with PgBouncer pooling)
DATABASE_URL="postgres://user:password@host:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Supabase direct connection (for Prisma migrations only)
DIRECT_URL="postgres://user:password@host:5432/postgres"

# Magic Eden API Bearer token
ME_BEARER_TOKEN="your-magic-eden-token"

# Berachain RPC
BERACHAIN_RPC_URL="https://rpc.berachain.com"

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# Public (safe to expose in browser)
NEXT_PUBLIC_CONTRACT_ADDRESS="0x6666397DFe9a8c469BF65dc744CB1C733416c420"
NEXT_PUBLIC_CHAIN_ID="80094"
NEXT_PUBLIC_ME_COLLECTION_SLUG="mibera333"

# =====================================================
# Analytics (Umami — server-side)
# =====================================================
UMAMI_HOST="https://your-umami-instance.com"
UMAMI_WEBSITE_ID="your-website-id"

# =====================================================
# Internal API (protects /api/internal/* routes)
# =====================================================
INTERNAL_API_KEY="generate-a-strong-random-key"

# =====================================================
# Bug report webhook (optional — Discord or Telegram)
# =====================================================
# WEBHOOK_URL="https://discord.com/api/webhooks/..."
